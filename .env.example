# ─────────────────────────────────────────────────────────────────────────────
# StudyTrack — Build-time Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Pass every key to Flutter at build time via --dart-define-from-file=.env
# so they are baked into the binary and never live in source code.
#
# NEVER commit .env to source control.  Only .env.example is tracked.
# .env is listed in .gitignore.
#
# Usage:
#   flutter build apk  --dart-define-from-file=.env --release
#   flutter build appbundle --dart-define-from-file=.env --release
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Gemini AI (required for AI Tutor and Weekly Wrapped) ───────────────
# Found in: Google AI Studio → API Keys
GEMINI_API_KEY=AIza...

# ── Sentry (optional but strongly recommended for production) ─────────────────
# Found in: Sentry Dashboard → Project Settings → SDK Setup → DSN
# Leave empty to disable crash reporting.
SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/789012

# ── Spotify (optional — enables ambient study music) ─────────────────────────
# Found in: Spotify Developer Dashboard → Your App → Client ID
# Leave empty to hide the music player widget.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# ── OAuth redirect URI (must match Supabase + AndroidManifest deep link) ─────
OAUTH_REDIRECT_URI=com.studytrack.app://callback

# ── OTA self-update certificate fingerprint (optional) ───────────────────────
# SHA-256 fingerprint of the APK signing certificate used to verify OTA updates.
# Generate with: keytool -printcert -file release.cer | grep SHA256
UPDATE_CERTIFICATE_SHA256=

# ── App environment tag (development | staging | production) ─────────────────
APP_ENV=production
