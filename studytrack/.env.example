# StudyTrack environment configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to the repository — it is excluded by .gitignore.
#
# Usage:
#   flutter run  --dart-define-from-file=.env
#   flutter build apk --release --dart-define-from-file=.env
#
# Where to get these values:
#   SUPABASE_URL + SUPABASE_ANON_KEY  →  Supabase Dashboard > Settings > API
#   GEMINI_API_KEY                    →  https://aistudio.google.com  (free tier)

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
GEMINI_API_KEY=your-gemini-api-key-here
